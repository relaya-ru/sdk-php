{
    "name": "relaya/sdk-php",
    "description": "Relaya MAX API PHP SDK",
    "keywords": [
        "relaya",
        "sdk",
        "max api",
        "php",
        "api",
        "messaging",
        "integrations"
    ],
    "homepage": "https://relaya.ru",
    "license": "proprietary",
    "authors": [
        {
            "name": "Relaya",
            "homepage": "https://relaya.ru"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.0 || ^9.0",
        "friendsofphp/php-cs-fixer": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "Relaya\\Sdk\\": "lib/",
            "Relaya\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Relaya\\Sdk\\Test\\": "test/"
        }
    },
    "type": "library",
    "extra": {
        "laravel": {
            "providers": [
                "Relaya\\Sdk\\Laravel\\RelayaSdkServiceProvider"
            ]
        }
    },
    "suggest": {
        "illuminate/support": "Laravel integration via auto-discovered service provider."
    }
}
